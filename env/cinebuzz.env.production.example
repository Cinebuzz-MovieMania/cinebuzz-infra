# Copy values into /etc/cinebuzz.env on EC2 (never commit real passwords).
# See docs/rds-and-dbeaver.md for RDS security groups and DBeaver.

SPRING_DATASOURCE_URL=jdbc:mysql://cinebuzz-db.csfgq2ecqa5b.us-east-1.rds.amazonaws.com:3306/cinebuzzdb
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=CHANGEME

JWT_SECRET=CHANGEME
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
