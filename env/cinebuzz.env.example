# Copy to EC2 as /etc/cinebuzz.env (never commit real values)
# RDS --db-name must be alphanumeric (e.g. cinebuzzdb). Instance id may be cinebuzz-db.
# Production template: env/cinebuzz.env.production.example — see docs/rds-and-dbeaver.md
SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_RDS_ENDPOINT:3306/cinebuzzdb
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=
JWT_SECRET=
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
CINEBUZZ_MAIL_FROM=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
