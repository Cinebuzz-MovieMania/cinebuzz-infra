# Copy to env/deploy.env (gitignored) and fill in. Then run scripts from cinebuzz-infra/scripts/

# EC2 SSH
DEPLOY_HOST=ec2-xxx.compute.amazonaws.com
DEPLOY_USER=ubuntu
# Path to your private key on this Mac (never commit the .pem file)
DEPLOY_KEY=/Users/you/.ssh/your-key.pem

# Frontend build only — public API base (no trailing slash)
VITE_API_BASE=http://YOUR_PUBLIC_IP/cinebuzz
